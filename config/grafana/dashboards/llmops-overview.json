          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GPU Util by MIG Slice",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "avg(DCGM_FI_DEV_GPU_UTIL) by (GPU_I_PROFILE, GPU_I_ID)",
          "legendFormat": "{{GPU_I_PROFILE}} / GI {{GPU_I_ID}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "state-timeline",
      "title": "OOM Risk State by MIG Slice",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "label_replace(((DCGM_FI_DEV_FB_USED{GPU_I_PROFILE=\"1g.5gb\"} / 4864) > bool 0.95) * 2 + ((DCGM_FI_DEV_FB_USED{GPU_I_PROFILE=\"1g.5gb\"} / 4864) > bool 0.85), \"slice\", \"$1 / GI $2\", \"GPU_I_PROFILE\", \"(.*)\")",
          "legendFormat": "{{GPU_I_PROFILE}} / GI {{GPU_I_ID}}",
          "refId": "A"
        },
        {
          "expr": "((DCGM_FI_DEV_FB_USED{GPU_I_PROFILE=\"2g.10gb\"} / 9984) > bool 0.95) * 2 + ((DCGM_FI_DEV_FB_USED{GPU_I_PROFILE=\"2g.10gb\"} / 9984) > bool 0.85)",
          "legendFormat": "{{GPU_I_PROFILE}} / GI {{GPU_I_ID}}",
          "refId": "B"
        },
        {
          "expr": "((DCGM_FI_DEV_FB_USED{GPU_I_PROFILE=\"3g.20gb\"} / 20096) > bool 0.95) * 2 + ((DCGM_FI_DEV_FB_USED{GPU_I_PROFILE=\"3g.20gb\"} / 20096) > bool 0.85)",
          "legendFormat": "{{GPU_I_PROFILE}} / GI {{GPU_I_ID}}",
          "refId": "C"
        }
      ],
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "rowHeight": 0.9
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OK"
                },
                "1": {
                  "text": "Warning"
                },
                "2": {
                  "text": "Critical/OOM risk"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      }
    },
