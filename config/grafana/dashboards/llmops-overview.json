      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "avg(DCGM_FI_DEV_FB_USED) by (GPU_I_PROFILE, GPU_I_ID)",
